<header>
  <a href="/">
    <img src="/images/logo-full.svg"></img>
  </a>

  {% if collections.pages | length %}
    <nav>
      {% for item in collections.pages %}
        <a class="undecorated-link" href="{{ item.url }}">{{ item.data.title }}</a>
      {% endfor %}
    </nav>
  {% endif %}
</header>