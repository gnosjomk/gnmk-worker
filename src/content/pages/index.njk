layout: base.njk
title: Hem
---

<div class="hero">
    <section class="content">
        <h1>Välkommen till Gnosjö Missionskyrka!</h1>
        <p> Vi vill erbjuda en öppen och generös gemenskap för alla oavsett bakgrund.<br />
        Vi tror att mötet med Jesus kan göra skillnad i våra liv.</p>
    </section>
</div>

{% if collections.activities | length %}
  <h2>Våra verksamheter</h2>
  <section class="activities">
    {% for item in collections.activities %}
      <section>
        <h3>{{ item.data.title }}</h3>
        <p>{{ item.data.blurb }}</p>
      </section>
    {% endfor %}
  </section>
{% endif %}