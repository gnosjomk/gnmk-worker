---
layout: base.njk
title: Nyheter
---
{% if collections.news | length %}
  <h1>Nyheter</h1>
  <section class="news">
    {% for item in collections.news %}
      <section>
        <a href="{{item.url}}">
            <h2>{{ item.data.title }}</h2>
            <p>{{ item.data.blurb }}</p>
        </a>
      </section>
    {% endfor %}
  </section>
{% endif %}